// ab-insights: 学習データ収集 + プロンプト管理基盤
// Vercel + Neon Postgres で運用。DATABASE_URL は env 経由で注入。

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url は prisma.config.ts の datasource.url 経由で env から読み込む (Prisma 7+)
}

// ===========================================
// 運用管理
// ===========================================

/// 単一管理者(複数人になったら後で分割)
model Admin {
  id           Int      @id @default(autoincrement())
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 管理者セッション(簡易 cookie ベース)
model Session {
  id        String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// ab-system 等の外部アプリからの API 認証トークン
/// token は作成時にのみ平文で返し、DB には hash のみ保存
model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String // 「ab-system production」等の識別名
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  active     Boolean   @default(true)
}

/// グローバル設定(学習 enabled フラグ等)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ===========================================
// 学習データ
// ===========================================

/// 画像生成イベント(ab-system からの webhook で記録)
model Event {
  id Int @id @default(autoincrement())
  /// ab-system 側のユーザー ID (opaque 文字列・匿名化)
  abSystemUserId String
  /// ab-system 側の表示名 (displayName || username、無ければ null)
  abSystemUserName String?
  /// ab-system の生成エンドポイント: 'generate-images' | 'improve-images' | etc.
  endpoint  String
  model     String? // gemini-3.1-flash-image-preview 等
  createdAt DateTime @default(now())

  // 入力コンテキスト
  genre              String?
  subGenre           String?
  gender             String?
  ageGroup           String?
  platform           String?
  appealType         String?
  appealText         String? // 最終的に採用された訴求文(書き換え後)
  appealOriginalText String? // AI が最初に提案した訴求文(選ばれた①②③の原文)
  appealSelectedIndex Int?   // 選んだサブ項目の番号 (1|2|3)
  additionalNote     String?
  // AI 修正(/api/edit-region)で記録する「AI に出した指示」。
  // ab-system からは [{kind, text, region?}, ...] の JSON 文字列で届く。
  aiEditInstructionsJson String?
  styleAxesJson      String? // JSON string
  urlAnalysisSummary String?
  promptFull         String? // Gemini に送った最終プロンプト(全文)
  promptHash         String? // 重複検出用

  // 行動シグナル(後から更新)
  imageCount           Int     @default(0)
  downloaded           Boolean @default(false)
  horizontallyExpanded Boolean @default(false)
  aiEdited             Boolean @default(false)
  regeneratedCount     Int     @default(0)
  hitScore             Float? // 0〜1 で自動計算

  // ===== ① 信号粒度・評価 (後追いで signal API で更新される) =====
  /// 生成完了 → 初回 DL までの経過時間(ms)。未DLなら null。
  decisionTimeMs   Int?
  /// 再生成の理由ラベル(client の UI で選択。'color'|'person'|'copy'|'layout'|'appeal'|'other' 等)
  regenerationReason String?
  /// ユーザー明示評価 1-5。DL 後に UI で付ける。
  rating           Int?
  /// 明示評価の短文コメント(任意)
  ratingComment    String?
  /// タグ(JSON 配列)。例: ["保守的","トレンド"]
  tagsJson         String?

  // ===== ② 文脈入力 (生成時に ab-system の form から来る・プロンプトには入れず保存だけ) =====
  /// キャンペーン目的: 'cv'|'awareness'|'lead'|'retargeting'
  campaignGoal       String?
  /// ターゲットの興味関心(JSON 配列)
  targetInterestsJson String?
  targetRegion       String?
  targetIncomeRange  String?
  budgetRange        String?
  targetCpa          Float?
  landingPageUrl     String?
  /// CV ポイント種別: 'purchase'|'signup'|'call'|'download'|'other'
  cvPointType        String?

  // ===== ⑤ 暗黙シグナル (セッション終了時にバッチで送られる集計値) =====
  /// ユーザーがこの生成画面に滞在した合計時間(ms)
  sessionDurationMs  Int?
  /// 全画像へのホバー合計時間(ms)。個別は EventImage.hoverMs 参照。
  totalHoverMs       Int?
  /// 拡大表示された回数(合計)
  zoomCount          Int?
  /// タブが切り替わった回数(離脱気味を測る)
  tabSwitchCount     Int?
  /// 比較画面の滞在時間(ms)
  comparisonViewMs   Int?
  /// 右クリック保存された回数(UI の DL ボタンを使わない裏ルート DL)
  rightClickSaveCount Int?

  // ===== ⑥ ネガティブ学習 =====
  /// AI 編集後に結果を破棄した (= 編集しても直らなかった)
  discardedAfterEdit Boolean @default(false)
  /// 再生成で何を変えたか差分情報(JSON)
  regenerationDiffJson String?

  images  EventImage[]
  aiEdits EventAiEdit[]

  @@index([genre, createdAt])
  @@index([abSystemUserId, createdAt])
  @@index([downloaded, horizontallyExpanded])
  @@index([campaignGoal, genre])
  @@index([rating])
}

/// 各イベントで生成された画像(64x64 サムネ相当)
model EventImage {
  id         Int     @id @default(autoincrement())
  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId    Int
  imageIndex Int // バリエーション番号
  thumbnail  Bytes? // 64x64 WebP 圧縮(~3-5KB)
  fullHash   String? // 元画像の SHA-256 (重複検出)
  downloaded Boolean @default(false)
  aiEdited   Boolean @default(false)

  // ===== ① 画像別 DL 詳細 =====
  /// この画像が DL された時刻(未 DL なら null)
  downloadedAt DateTime?
  /// 同一 Event 内で DL された順位(1 = 最初、null = 未 DL)
  downloadRank Int?

  // ===== ⑤ 暗黙シグナル(画像単位) =====
  /// この画像にホバーした合計時間(ms)
  hoverMs   Int?
  /// この画像を拡大表示した回数
  viewCount Int?

  @@index([eventId])
}

/// AI 編集で触られた内容(ネガティブシグナル)
model EventAiEdit {
  id          Int      @id @default(autoincrement())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     Int
  kind        String // 'text' | 'person' | 'background' | 'color' | 'product_swap' | 'remove'
  instruction String
  createdAt   DateTime @default(now())

  // ===== ⑥ ネガティブ学習 =====
  /// この編集指示の結果が最終的に破棄されたか(= 直らなかった)
  discarded   Boolean  @default(false)

  @@index([eventId])
  @@index([kind])
}

// ===========================================
// プロンプト管理
// ===========================================

/// ジャンル別の追加プロンプトブロック
/// admin が管理画面で作成・編集 → ab-system が生成時に GET /api/prompts/:genre で取得して挿入
model GenrePrompt {
  id        Int      @id @default(autoincrement())
  genre     String // '化粧品' | 'サプリ' | ... (「共通」「*」も可)
  blockName String // UI 表示用の名前 (例:「効果実感訴求」)
  content   String // プロンプトに挿入される本文
  enabled   Boolean  @default(true)
  priority  Int      @default(0) // 並び順・プロンプト内での順序
  note      String? // admin メモ(意図)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([genre, enabled, priority])
}

/// ジャンル別の集計済みインサイト(定期バッチで更新)
model GenreInsight {
  id                 Int      @id @default(autoincrement())
  genre              String   @unique
  sampleSize         Int      @default(0)
  downloadRate       Float? // DL率 0〜1
  expansionRate      Float? // 横展開率 0〜1
  avgHitScore        Float?
  topAppealTypesJson String? // JSON array
  topStyleAxesJson   String?
  editKindStatsJson  String? // AI 編集 kind 別頻度
  updatedAt          DateTime @updatedAt
}
