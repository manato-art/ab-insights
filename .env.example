# ===========================================
# ab-insights 環境変数テンプレート
# ===========================================
# .env.local (local 用) または Vercel の env にそれぞれ設定してください。

# Neon Postgres 接続文字列 (Vercel Marketplace で Neon を追加すると自動注入される)
# 手動の場合は postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# OpenAI API キー (学習データの AI 要約に使用・任意)
# 未設定でも /upload は動く(AI 要約なしで保存される)
OPENAI_API_KEY=

# 初回 seed 時の admin パスワード (未設定なら 'Admin123' が使われる・本番必須)
INITIAL_ADMIN_PASSWORD=
